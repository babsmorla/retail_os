<!DOCTYPE html>
<html class="h-full bg-slate-50">
  <head>
    <title><%= content_for(:title) || "RetailOS" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      body { font-family: 'Inter', sans-serif; }
    </style>
  </head>
  <body class="h-full flex flex-col text-slate-900 selection:bg-indigo-100 selection:text-indigo-900">
   <header class="bg-white/90 border-b backdrop-blur-md border-slate-200/80 sticky top-0 z-50 shrink-0 shadow-xs">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between gap-6">
    <!-- Left Section: App Brand -->
    <div class="flex items-center gap-8">
      <span class="text-xl font-extrabold text-[#0a255c] tracking-tight">RetailOS</span>
      <!-- Only show main navigation links if a user is actually logged in -->
      <% if respond_to?(:user_signed_in?) && user_signed_in? %>
        <nav class="hidden md:flex items-center gap-1">
          <%= link_to "Dashboard", shop_keeper_dashboard_path, class: "px-3.5 py-2 text-sm font-semibold text-slate-600 hover:text-[#0a255c] hover:bg-slate-50 rounded-xl transition" %>
          <%= link_to "New Sale", new_shop_keeper_sale_path, class: "px-3.5 py-2 text-sm font-semibold text-slate-600 hover:text-[#0a255c] hover:bg-slate-50 rounded-xl transition" %>
          <%= link_to "Sales History", shop_keeper_sales_path, class: "px-3.5 py-2 text-sm font-semibold text-slate-600 hover:text-[#0a255c] hover:bg-slate-50 rounded-xl transition" %>
          <%= link_to "Inventory", shop_keeper_products_path, class: "px-3.5 py-2 text-sm font-semibold text-slate-600 hover:text-[#0a255c] hover:bg-slate-50 rounded-xl transition" %>
        </nav>
      <% end %>
    </div>
    <!-- Right Section: Profile Info or Auth Fallback -->
    <div class="flex items-center gap-5 ml-auto">
      <% if respond_to?(:user_signed_in?) && user_signed_in? %>
        <!-- DISPLAYED ONLY WHEN SIGNED IN -->
        <!-- Store Context Pill -->
        <% if respond_to?(:current_store) && current_store.present? %>
          <div class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-blue-50/70 border border-blue-100/80 text-xs font-semibold text-blue-700">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-blue-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h2.64m-14-10.5V6a2.25 2.25 0 0 1 2.25-2.25h5.5A2.25 2.25 0 0 1 16.12 6v4.5m-9.75 0h9.75" />
            </svg>
            <span><%= current_store.name %></span>
          </div>
          <div class="hidden sm:block h-5 w-px bg-slate-200"></div>
        <% end %>
        <!-- Profile Context Info -->
        <div class="text-right">
          <p class="text-sm font-bold text-slate-900 tracking-tight "><%= current_user.full_name %></p>
          <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider mt-1">
            <%= current_user.respond_to?(:role) ? current_user.role.to_s.humanize : "Staff" %>
          </p>
        </div>
        <div class="h-5 w-px bg-slate-200"></div>
        <!-- Action: Terminate Session -->
        <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, 
                    class: "px-3.5 py-2 text-xs font-bold text-red-600 bg-red-50 hover:bg-red-100 border border-red-100/30 rounded-xl transition shadow-2xs active:scale-98" %>
      <% else %>
        <!-- DISPLAYED ONLY ON LOGIN / AUTH SCREENS -->
        <%= link_to "Sign In", new_user_session_path, class: "text-sm font-semibold text-slate-600 hover:text-[#0a255c] transition" unless current_page?(new_user_session_path) %>
        <span class="text-xs text-slate-400 font-medium bg-slate-50 px-3 py-1.5 rounded-lg border border-slate-200/60">
          Secure Portal
        </span>
      <% end %>
    </div>
  </div>
</header>
    <div id="flash" class="fixed top-20 right-4 z-[9999]">
      <%= render "layouts/flash" %>
    </div>
    <main class="flex-1 overflow-y-auto bg-slate-50/50">
      <div class="max-w-[1440px] mx-auto p-6">
        <%= yield %>
      </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>