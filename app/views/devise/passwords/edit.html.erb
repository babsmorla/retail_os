<div class="min-h-screen w-full flex flex-col lg:flex-row bg-white font-sans antialiased text-slate-900 select-none">
  <!-- ==================== LEFT COLUMN: PREMIUM BRANDING & METADATA CANVAS ==================== -->
  <div class="hidden lg:flex w-full lg:w-[42%] flex-shrink-0 bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 p-6 sm:p-10 lg:p-12 flex-col justify-between relative h-screen lg:h-screen lg:max-h-screen overflow-hidden lg:sticky lg:top-0 border-b lg:border-b-0 lg:border-r border-slate-800/40 select-none [&-::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
    <!-- Top-Right Ambient Warm Spotlight Glow -->
    <div class="absolute -top-20 -right-20 w-[450px] h-[450px] bg-amber-500/10 rounded-full blur-[130px] pointer-events-none z-0"></div>
    <!-- Seamless Technical Grid Architecture Line Overlay -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-[size:3rem_3rem] opacity-10 pointer-events-none z-0"></div>
    <!-- Top Row: App Header Identity Branding -->
    <div class="z-10 flex items-center gap-2.5">
      <div class="h-8 w-8 rounded-xl bg-amber-500 flex items-center justify-center shadow-md shadow-amber-500/20">
        <span class="text-slate-950 font-black text-xs tracking-wider">R</span>
      </div>
      <span class="text-sm font-black text-white tracking-tight">
        Retail<span class="text-amber-400">OS</span>
      </span>
    </div>
    <!-- Center Presentation Headline Typography -->
    <div class="z-10 my-auto w-full max-w-md text-left py-2">
      <h1 class="text-4xl sm:text-5xl font-black text-white tracking-tight leading-[1.1] mb-4">
        Update Your<br/>
        Password
      </h1>
      <p class="text-slate-400 text-xs sm:text-sm font-medium leading-relaxed max-w-[300px]">
        Create a powerful new authentication layer to protect your operational business database.
      </p>
    </div>
    <!-- Bottom Row: Reassurance Status Security Module Info -->
    <div class="z-10 bg-white/[0.02] border border-white/5 p-4 rounded-2xl w-full mt-auto flex items-center gap-3.5">
      <div class="w-8 h-8 rounded-xl bg-amber-500/10 text-amber-400 flex items-center justify-center flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v-6.75a2.25 2.25 0 0 0 2.25-2.25Z" />
        </svg>
      </div>
      <div>
        <h4 class="text-xs font-bold text-white tracking-wide">Secure Token Verification</h4>
        <p class="text-[10px] text-slate-500 font-medium mt-0.5">Session payload is fully encrypted to prevent hijacking parameters.</p>
      </div>
    </div>
  </div>
  <!-- ==================== RIGHT COLUMN: CRISP LIGHT FORM WORKSPACE HUB ==================== -->
  <div class="w-full lg:w-[58%] bg-white p-6 sm:p-12 lg:p-16 flex flex-col justify-between min-h-screen">
    <!-- Top Action Context Header Link -->
    <div class="w-full flex justify-end text-xs font-medium mb-12 lg:mb-4">
      <span class="text-slate-400">Decided not to switch?</span>
      <%= link_to "Cancel & Log In", new_session_path(resource_name), class: "text-slate-900 font-bold hover:underline ml-1.5 transition" %>
    </div>
    <!-- Core Interactive Form Framework Area -->
    <div class="w-full max-w-md mx-auto my-auto py-4">
      <!-- Primary Heading Identity Identification -->
      <div class="mb-6 text-left">
        <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 sm:text-3xl">Change your password</h2>
        <p class="text-slate-400 text-xs font-medium mt-1">Provide and re-verify your new workspace access combination key below.</p>
      </div>
      <!-- Devise Form Submitter Block Architecture -->
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5 w-full" }) do |f| %>
        <!-- Nested Form Errors Alert Hub -->
        <%= render "devise/shared/error_messages", resource: resource %>
        <!-- Crucial Hidden Token Parameter Injector -->
        <%= f.hidden_field :reset_password_token %>
        <!-- New Password Input Wrapper Box -->
        <div>
          <div class="flex items-baseline justify-between mb-1.5">
            <%= f.label :password, "New Password", class: "block text-[11px] font-bold text-slate-500 uppercase tracking-wider" %>
            <% if @minimum_password_length %>
              <span class="text-[10px] text-slate-400 font-medium">(<%= @minimum_password_length %> characters minimum)</span>
            <% end %>
          </div>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password", placeholder: "••••••••", 
              class: "block w-full px-4 py-3 bg-slate-50 border border-slate-200/70 rounded-xl focus:bg-white focus:outline-none focus:border-amber-500 focus:ring-4 focus:ring-amber-500/10 text-xs font-medium text-slate-700 placeholder-slate-400 transition" %>
        </div>
        <!-- Confirm Password Input Wrapper Box -->
        <div>
          <%= f.label :password_confirmation, "Confirm New Password", class: "block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1.5" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••", 
              class: "block w-full px-4 py-3 bg-slate-50 border border-slate-200/70 rounded-xl focus:bg-white focus:outline-none focus:border-amber-500 focus:ring-4 focus:ring-amber-500/10 text-xs font-medium text-slate-700 placeholder-slate-400 transition" %>
        </div>
        <!-- High-Contrast Primary Submit Execution Action -->
        <div class="pt-2">
          <%= f.submit "Change my password", 
              data: { disable_with: "Updating security elements..." },
              class: "w-full cursor-pointer bg-gradient-to-r from-slate-900 to-slate-800 hover:from-slate-950 hover:to-slate-950 text-white font-bold py-3.5 px-4 rounded-xl transition duration-150 text-xs tracking-wide shadow-lg shadow-slate-900/10 text-center" %>
        </div>
      <% end %>
      <!-- Custom Stylized Shared Route Links Navigation Matrix Footer Container -->
      <div class="mt-8 pt-5 border-t border-slate-100 flex flex-wrap gap-x-4 gap-y-2 justify-center text-[11px] font-bold text-slate-400">
        <%= render "devise/shared/links" %>
      </div>
    </div>
    <!-- Workspace View System Base Signature Footer Row -->
    <div class="flex items-center justify-between w-full pt-4 border-t border-slate-100 text-[9px] font-bold text-slate-400 tracking-wide mt-auto">
      <div>
        <p class="normal-case">Powered by <span class="text-slate-500">Babs Technologies</span> &bull; 2026</p>
      </div>
      <div class="flex items-center gap-4">
        <a href="#" class="hover:text-slate-600 transition">Terms</a>
        <a href="#" class="hover:text-slate-600 transition">Privacy</a>
      </div>
    </div>
  </div>
</div>