<%# app/views/shop_keeper/categories/show.html.erb %>
<div class="min-h-screen bg-slate-50/50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto space-y-8">
    <div class="flex items-center justify-between">
      <%= link_to shop_keeper_categories_path, data: { turbo_frame: "_top" }, class: "inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-slate-800 transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Categories
      <% end %>
      <div class="flex items-center gap-3">
        <%= link_to edit_shop_keeper_category_path(@category), class: "inline-flex items-center gap-1.5 bg-white border border-slate-200 text-slate-700 hover:text-slate-900 font-semibold py-2 px-4 rounded-xl shadow-sm hover:shadow transition text-sm" do %>
          <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
          </svg>
          Edit Category
        <% end %>
      </div>
    </div>
    <% 
      color_classes = case @category.color
        when 'blue' then { bg: 'bg-blue-50', text: 'text-blue-600', border: 'border-blue-100/50' }
        when 'indigo' then { bg: 'bg-indigo-50', text: 'text-indigo-600', border: 'border-indigo-100/50' }
        when 'amber' then { bg: 'bg-amber-50', text: 'text-amber-600', border: 'border-amber-100/50' }
        when 'emerald' then { bg: 'bg-emerald-50', text: 'text-emerald-600', border: 'border-emerald-100/50' }
        when 'pink' then { bg: 'bg-pink-50', text: 'text-pink-600', border: 'border-pink-100/50' }
        when 'rose' then { bg: 'bg-rose-50', text: 'text-rose-600', border: 'border-rose-100/50' }
        else { bg: 'bg-blue-50', text: 'text-blue-600', border: 'border-blue-100/50' }
      end
    %>
    <div class="bg-white rounded-3xl border border-slate-200/60 p-6 sm:p-8 shadow-sm flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div class="flex items-start gap-5">
        <div class="h-16 w-16 rounded-2xl flex items-center justify-center shrink-0 <%= color_classes[:bg] %> <%= color_classes[:text] %> border <%= color_classes[:border] %>">
          <% if @category.icon == 'print' %>
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>
          <% elsif @category.icon == 'image' %>
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a1 1 0 011.414 0L16 18m-2-2l1.586-1.586a1 1 0 011.414 0L21 20M12 3v1M12 20v1M4 12H3m18 0h-1m-1.293-7.293l-.707.707M19.07 19.07l-.707-.707M6.343 17.657l-.707-.707M6.343 6.343l-.707-.707" /></svg>
          <% elsif @category.icon == 'layers' %>
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
          <% else %>
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2" /></svg>
          <% end %>
        </div>
        <div class="space-y-1">
          <div class="flex flex-wrap items-center gap-2.5">
            <h1 class="text-2xl font-bold text-slate-900 tracking-tight"><%= @category.name %></h1>
            <% if @category.active? %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/10">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                Active
              </span>
            <% else %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-slate-100 text-slate-600 ring-1 ring-slate-400/10">
                <span class="h-1.5 w-1.5 rounded-full bg-slate-400"></span>
                Draft
              </span>
            <% end %>
          </div>
          <p class="text-slate-500 max-w-2xl text-sm leading-relaxed">
            <%= @category.description.presence || "No description provided for this category." %>
          </p>
        </div>
      </div>
      <div class="shrink-0 bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-center min-w-[140px]">
        <p class="text-2xl font-bold text-slate-950"><%= @category.products.count %></p>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mt-0.5"><%= 'Product'.pluralize(@category.products.count) %></p>
      </div>
    </div>
    <div class="space-y-4">
      <div class="flex items-center justify-between pb-3 border-b border-slate-200/60">
        <div>
          <h2 class="text-lg font-bold text-slate-900">Products under this Category</h2>
          <p class="text-xs text-slate-500 mt-0.5">Sub-items configured to use this categorization.</p>
        </div>
        <% if respond_to?(:new_shop_keeper_product_path) %>
          <%= link_to new_shop_keeper_product_path(category_id: @category.id), class: "inline-flex items-center gap-1.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-3.5 rounded-xl transition text-xs cursor-pointer" do %>
            <span>+</span> Add Product
          <% end %>
        <% end %>
      </div>
      <% if @category.products.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% @category.products.each do |product| %>
            <div class="bg-white rounded-2xl border border-slate-200/60 p-5 shadow-sm flex flex-col justify-between hover:border-slate-300 transition duration-150">
              <div class="space-y-3">
                <div class="flex items-start justify-between gap-4">
                  <div class="space-y-0.5">
                    <h3 class="font-bold text-slate-900 line-clamp-1">
                      <%= product.name %>
                    </h3>
                    <% if product.active == false %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-rose-50 text-rose-600 ring-1 ring-rose-600/10">Inactive</span>
                    <% end %>
                  </div>
                  <span class="text-sm font-bold text-slate-950 bg-slate-50 border border-slate-100 px-2.5 py-1 rounded-lg shrink-0">
                    $<%= number_with_precision(product.unit_price, precision: 2) %>
                  </span>
                </div>
                <div class="flex items-center gap-3 text-[11px] font-bold">
                  <% if product.quantity_on_hand <= (product.low_stock_threshold || product.reorder_level || 5) %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-amber-50 text-amber-700 ring-1 ring-amber-600/10">
                      <span class="h-1 w-1 rounded-full bg-amber-500"></span>
                      Low Stock: <%= product.quantity_on_hand %> left
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/10">
                      <span class="h-1 w-1 rounded-full bg-emerald-500"></span>
                      Stock: <%= product.quantity_on_hand %>
                    </span>
                  <% end %>
                </div>
              </div>
              <div class="mt-5 pt-4 border-t border-slate-100/80 flex items-center justify-between text-xs text-slate-400 font-semibold">
                <span>
                  ID: #<%= product.id %>
                </span>
                <% if product.sku.present? %>
                  <span class="bg-slate-50 text-slate-600 px-2 py-0.5 rounded border border-slate-100 font-mono tracking-tight text-[11px]">
                    SKU: <%= product.sku %>
                  </span>
                <% else %>
                  <span class="text-slate-300 italic font-normal text-[11px]">
                    No SKU
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white rounded-3xl border border-slate-200/60 p-12 text-center shadow-sm">
          <div class="h-12 w-12 bg-slate-50 text-slate-400 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-slate-900">No products assigned</h3>
          <p class="text-xs text-slate-500 mt-1 max-w-xs mx-auto">There are currently no products registered under the <%= @category.name %> category.</p>
          <% if respond_to?(:new_shop_keeper_product_path) %>
            <div class="mt-5">
              <%= link_to new_shop_keeper_product_path(category_id: @category.id), class: "inline-flex items-center gap-1.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-xl shadow-sm transition text-xs cursor-pointer" do %>
                Add Your First Product
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>