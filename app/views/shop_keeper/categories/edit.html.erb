<%= turbo_frame_tag "category_modal_frame" do %>
  <div class="fixed inset-0 z-50 overflow-y-auto" 
       x-data="{ 
         openModal: true,
         selectedIcon: '<%= @category.icon.presence || "copy" %>',
         selectedColor: '<%= @category.color.presence || "blue" %>'
       }" 
       x-show="openModal"
       @keydown.escape.window="openModal = false; Turbo.visit('<%= shop_keeper_categories_path %>')">
    <div class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity" @click="openModal = false; Turbo.visit('<%= shop_keeper_categories_path %>')"></div>
    <div class="flex min-h-full items-center justify-center p-4 sm:p-6 lg:p-8">
      <div class="bg-white rounded-3xl border border-slate-100 shadow-2xl max-w-xl w-full overflow-hidden relative transform transition-all"
           x-show="openModal"
           x-transition:enter="transition ease-out duration-300"
           x-transition:enter-start="opacity-0 scale-95"
           x-transition:enter-end="opacity-100 scale-100"
           x-transition:leave="transition ease-in duration-200"
           x-transition:leave-start="opacity-100 scale-100"
           x-transition:leave-end="opacity-0 scale-95">
        <div class="px-8 pt-8 pb-6 border-b border-slate-50 flex items-center justify-between">
          <div>
            <h1 class="text-xl font-bold text-slate-900">
              <%= @category.new_record? ? "Create Category" : "Edit Category" %>
            </h1>
            <p class="text-xs text-slate-500 mt-1">Configure icons, statuses, and options for your catalog group</p>
          </div>
          <%= link_to shop_keeper_categories_path, data: { turbo_frame: "_top" }, class: "text-slate-400 hover:text-slate-600 transition p-1.5 hover:bg-slate-50 rounded-xl" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          <% end %>
        </div>
        <%= form_for([:shop_keeper, @category], html: { class: "p-8 space-y-6", id: "category-form", data: { turbo_frame: "_top" } }) do |f| %>
          <% if @category.errors.any? %>
            <div class="bg-rose-50 border border-rose-200 rounded-2xl p-4 text-sm text-rose-800">
              <p class="font-bold mb-1">Please correct the following errors:</p>
              <ul class="list-disc list-inside space-y-1 text-xs">
                <% @category.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <%= f.hidden_field :icon, "x-model": "selectedIcon" %>
          <%= f.hidden_field :color, "x-model": "selectedColor" %>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-3">Icon & Color</label>
            <div class="flex items-center gap-2.5 flex-wrap">
              <button type="button" 
                      @click="selectedIcon = 'copy'; selectedColor = 'blue'"
                      :class="selectedIcon === 'copy' ? 'border-blue-600 ring-4 ring-blue-100' : 'border-slate-100 hover:border-slate-200'"
                      class="h-11 w-11 rounded-xl flex items-center justify-center bg-blue-50 text-blue-600 border-2 transition cursor-pointer">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2" /></svg>
              </button>
              <button type="button" 
                      @click="selectedIcon = 'print'; selectedColor = 'indigo'"
                      :class="selectedIcon === 'print' ? 'border-indigo-600 ring-4 ring-indigo-100' : 'border-slate-100 hover:border-slate-200'"
                      class="h-11 w-11 rounded-xl flex items-center justify-center bg-indigo-50 text-indigo-600 border-2 transition cursor-pointer">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>
              </button>
              <button type="button" 
                      @click="selectedIcon = 'image'; selectedColor = 'amber'"
                      :class="selectedIcon === 'image' ? 'border-amber-600 ring-4 ring-amber-100' : 'border-slate-100 hover:border-slate-200'"
                      class="h-11 w-11 rounded-xl flex items-center justify-center bg-amber-50 text-amber-600 border-2 transition cursor-pointer">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a1 1 0 011.414 0L16 18m-2-2l1.586-1.586a1 1 0 011.414 0L21 20M12 3v1M12 20v1M4 12H3m18 0h-1m-1.293-7.293l-.707.707M19.07 19.07l-.707-.707M6.343 17.657l-.707-.707M6.343 6.343l-.707-.707" /></svg>
              </button>
              <button type="button" 
                      @click="selectedIcon = 'layers'; selectedColor = 'emerald'"
                      :class="selectedIcon === 'layers' ? 'border-emerald-600 ring-4 ring-emerald-100' : 'border-slate-100 hover:border-slate-200'"
                      class="h-11 w-11 rounded-xl flex items-center justify-center bg-emerald-50 text-emerald-600 border-2 transition cursor-pointer">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
              </button>
            </div>
          </div>
          <div>
            <%= f.label :name, "Category Name", class: "block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5" %>
            <%= f.text_field :name, placeholder: "e.g., Printing services", class: "block w-full px-4 py-3 bg-slate-50/50 border border-slate-200 rounded-xl focus:bg-white focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 text-sm transition" %>
          </div>
          <div>
            <%= f.label :description, "Description", class: "block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5" %>
            <%= f.text_area :description, rows: 3, placeholder: "Short description of this category...", class: "block w-full px-4 py-3 bg-slate-50/50 border border-slate-200 rounded-xl focus:bg-white focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 text-sm transition resize-none" %>
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-3">Category Type</label>
            <div class="grid grid-cols-2 gap-2 bg-slate-100/60 p-1.5 rounded-2xl border border-slate-200/50">
              <% Category.category_types.keys.each do |type| %>
                <label class="cursor-pointer">
                  <%= f.radio_button :category_type, type, class: "sr-only peer" %>
                  <div class="py-2.5 text-center text-xs font-bold text-slate-500 rounded-xl transition duration-150 peer-checked:bg-blue-600 peer-checked:text-white peer-checked:shadow-sm">
                    <%= type.titleize %>
                  </div>
                </label>
              <% end %>
            </div>
          </div>
          <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100">
            <div>
              <span class="block text-sm font-bold text-slate-800">Active</span>
              <span class="text-xs text-slate-500">Visible in POS and reports</span>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <%= f.check_box :active, class: "sr-only peer" %>
              <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
            </label>
          </div>
          <div class="grid grid-cols-2 gap-4 pt-4 border-t border-slate-50">
            <%= link_to "Cancel", shop_keeper_categories_path, data: { turbo_frame: "_top" }, class: "py-3.5 px-4 text-center rounded-xl bg-slate-50 hover:bg-slate-100 text-slate-700 font-bold text-sm transition" %>
            <%= f.submit @category.new_record? ? "Create Category" : "Save Changes", class: "py-3.5 px-4 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm shadow-lg shadow-blue-100 hover:shadow-xl transition cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>