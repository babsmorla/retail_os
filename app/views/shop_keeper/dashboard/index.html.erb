<div class="min-h-screen bg-slate-50/70 p-6 md:p-8 flex flex-col gap-6 font-sans antialiased text-slate-800">
  <!-- Header Welcome Area -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-black text-slate-900 tracking-tight">Shop Keeper Dashboard</h1>
      <p class="text-slate-500 text-xs font-semibold mt-1">
        Welcome back, <span class="text-blue-600 font-bold"><%= current_user.full_name %></span>!
      </p>
    </div>
    <div class="hidden sm:flex items-center gap-2 bg-white px-3 py-1.5 rounded-xl border border-slate-200/60 shadow-sm text-xs font-semibold text-slate-500">
      <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
      System Live
    </div>
  </div>
  <!-- Top Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Stat 1: Today's Sales -->
    <div class="bg-white border border-slate-200/50 rounded-2xl p-6 shadow-sm flex justify-between items-start transition hover:shadow-md">
      <div>
        <p class="text-slate-400 text-xs font-bold uppercase tracking-wider">Today's Sales</p>
        <h2 class="text-3xl font-black text-slate-900 mt-2.5 tracking-tight"><%= @today_sales_count %></h2>
        <div class="flex items-center gap-2 mt-4 text-slate-500 text-xs font-bold" 
           x-data="{ time: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) }" 
           x-init="setInterval(() => time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }), 60000)">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span x-text="time"></span>
        </div>
      </div>
      <div class="bg-blue-50 text-blue-600 p-2.5 rounded-xl">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" /></svg>
      </div>
    </div>
    <!-- Stat 2: Today's Revenue -->
    <div class="bg-white border border-slate-200/50 rounded-2xl p-6 shadow-sm flex justify-between items-start transition hover:shadow-md">
      <div>
        <p class="text-slate-400 text-xs font-bold uppercase tracking-wider">Today's Revenue</p>
        <h2 class="text-3xl font-black text-emerald-600 mt-2.5 tracking-tight"><%= @today_revenue_formatted %></h2>
        <div class="flex items-center gap-2 mt-4 text-slate-500 text-xs font-bold">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          <span><%= Time.current.strftime("%B %d, %Y") %></span>
        </div>
      </div>
      <div class="bg-emerald-50 text-emerald-500 w-10 h-10 rounded-xl flex items-center justify-center font-black text-base"> ₵</div>
    </div>
    <!-- Stat 3: Current Shift (Bold Clock) -->
    <div class="bg-white border border-slate-200/50 rounded-2xl p-6 shadow-sm flex flex-col justify-center      transition hover:shadow-md"
       x-data="{ time: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' }) }" 
       x-init="setInterval(() => time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' }), 1000)">
      <div>
        <p class="text-slate-400 text-xs font-bold uppercase tracking-wider mb-2">Current Shift</p>
        <div class="flex items-center gap-2">
          <h2 class="text-5xl font-black text-slate-900 tracking-tight tabular-nums" x-text="time"></h2>
        </div>
      </div>
    </div>
  </div>
  <!-- Banner Action Container (New Sale POS Entry) -->
  <div class="bg-[#0b1d3d] rounded-2xl p-6 md:p-8 flex flex-col sm:flex-row items-center justify-between gap-6 shadow-xl shadow-slate-900/10">
    <div>
      <h2 class="text-xl font-black text-white tracking-tight">Start a New Sale</h2>
      <p class="text-slate-300/80 text-xs font-semibold mt-1">Open the POS to process a new transaction quickly</p>
    </div>
    <%= link_to new_shop_keeper_sale_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs px-5 py-3 rounded-xl flex items-center gap-2 transition duration-150 active:scale-95 shadow-lg shadow-blue-600/10" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4.5 h-4.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      New Sale
    <% end %>
  </div>
  <!-- Dual Split Lists Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Panel Left: Recent Receipts -->
    <div class="bg-white border border-slate-200/50 rounded-2xl p-6 shadow-sm">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-sm font-black text-slate-900 tracking-tight">Recent Receipts</h3>
        <%= link_to "View all", shop_keeper_sales_path, class: "text-blue-600 hover:text-blue-700 text-xs font-bold transition" %>
      </div>
      <div class="divide-y divide-slate-100 flex flex-col">
        <% if @recent_receipts.present? %>
          <% @recent_receipts.each do |receipt| %>
            <div class="flex items-center justify-between py-4 first:pt-0 last:pb-0">
              <div class="flex items-center gap-3">
                <div class="bg-blue-50 text-blue-600 p-2 rounded-xl">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-xs font-bold text-slate-950">
                    #<%= receipt.receipt_number %>
                  </h4>
                  <p class="text-[10px] font-bold text-slate-400 mt-0.5">
                    <%= receipt.sale_items.count %> items · 
                    <%= receipt.payment_method.humanize %>
                  </p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="text-right">
                  <p class="text-xs font-extrabold text-slate-950">GHS <%= number_with_precision(receipt.grand_total, precision: 2) %></p>
                  <p class="text-[9px] font-bold text-slate-400 mt-0.5 uppercase"><%= receipt.created_at.strftime('%I:%M %p') %></p>
                </div>
                <% if receipt.receipt.present? %>
                  <%= link_to shop_keeper_receipt_path(receipt.receipt),
                  target: "_blank",
                  class: "text-slate-400 hover:text-slate-600 transition p-1 rounded hover:bg-slate-50" do %>
                    <svg xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="w-4 h-4">
                      <path stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 1.252a1.125 1.125 0 01-1.107 1.328H7.218a1.125 1.125 0 01-1.107-1.328L6.34 18m11.318 0h-11.32m12-9V5.25A2.25 2.25 0 0016.5 3h-9A2.25 2.25 0 005.25 5.25V9m13.5 0H5.25" />
                    </svg>
                  <% end %>
                <% else %>
                  <span class="text-[10px] font-bold text-red-400 uppercase italic p-1">No Receipt</span>
                <% end %>
              </div>
            </div>
          <% end %>
        <% else %>
          <!-- Default UI Fallback Items -->
          <p class="text-gray-400">
            No sales today
          </p>
        <% end %>
      </div>
    </div>
    <!-- Panel Right: Recent Transactions -->
    <div class="bg-white border border-slate-200/50 rounded-2xl p-6 shadow-sm">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-sm font-black text-slate-900 tracking-tight">Recent Transactions</h3>
        <%= link_to "View all", shop_keeper_sales_path, class: "text-blue-600 hover:text-blue-700 text-xs font-bold transition" %>
      </div>
      <div class="divide-y divide-slate-100 flex flex-col">
        <% if @recent_transactions.present? %>
          <% @recent_transactions.each do |tx| %>
            <div class="flex items-center justify-between py-4 first:pt-0 last:pb-0">
              <div class="flex items-center gap-3">
                <div class="bg-emerald-50 text-emerald-500 p-2 rounded-xl">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-xs font-bold text-slate-950"> #<%= tx.receipt_number %></h4>
                  <p class="text-[10px] font-bold text-slate-400 mt-0.5">
                    <%= tx.sale_items.count %> items · 
                    <%= tx.payment_method.humanize %>
                  </p>
                </div>
              </div>
              <div class="flex items-center gap-6">
                <div class="text-right">
                  <p class="text-xs font-extrabold text-slate-950">GHS <%= number_with_precision(tx.grand_total, precision: 2) %></p>
                  <p class="text-[9px] font-bold text-slate-400 mt-0.5 uppercase"><%= tx.created_at.strftime('%I:%M %p') %></p>
                </div>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-600">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                  Completed
                </span>
              </div>
            </div>
          <% end %>
        <% else %>
          <!-- Default UI Fallback Items -->
          <p class="text-gray-400">
            No transactions today
          </p>
        <% end %>
      </div>
    </div>
  </div>
  <!-- Bottom Quick Actions Grid -->
  
</div>