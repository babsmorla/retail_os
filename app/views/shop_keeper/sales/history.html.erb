<% content_for :title, "Transaction History" %>
<div class="p-8 max-w-[1600px] mx-auto space-y-6">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-2xl font-black text-slate-900">All Transactions</h1>
      <p class="text-slate-500 text-sm font-medium">Detailed view of every sale recorded.</p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Export CSV", shop_keeper_sales_path(format: :csv), class: "px-4 py-2 bg-blue-600 text-white rounded-xl text-xs font-bold hover:bg-blue-700 transition" %>
    </div>
  </div>
  <div class="bg-white p-4 border border-slate-200 rounded-2xl shadow-sm">
    <%= form_with url: history_shop_keeper_sales_path, method: :get, class: "flex gap-4" do |f| %>
      <%= f.text_field :query, value: params[:query], placeholder: "Search by Receipt ID...", class: "flex-1 border-slate-200 rounded-lg p-2 text-xs focus:ring-2 focus:ring-blue-500" %>
      <%= f.submit "Filter", class: "bg-slate-900 text-white px-6 py-2 rounded-lg text-xs font-bold hover:bg-slate-800 transition" %>
    <% end %>
  </div>
  <div class="bg-white border border-slate-200/60 rounded-2xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto w-full">
      <table class="w-full min-w-[700px] border-collapse text-left text-xs font-semibold">
        <thead>
          <tr class="bg-slate-50/75 border-b border-slate-100 text-[10px] uppercase font-bold text-slate-400 tracking-wider">
            <th class="py-4 px-6">Receipt</th>
            <th class="py-4 px-4">Staff</th>
            <th class="py-4 px-4">Customer</th>
            <th class="py-4 px-4">Payment</th>
            <th class="py-4 px-4 text-right">Amount</th>
            <th class="py-4 px-6 text-center">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-700">
          <% @sales.each do |sale| %>
            <tr class="hover:bg-slate-50/50 transition-colors">
              <td class="py-4 px-6 font-bold text-slate-900"><%= sale.receipt_number || sale.id %></td>
              <td class="py-4 px-4 text-slate-600 font-medium">
                <% if sale.shop_keeper %>
                  <div class="font-bold"><%= sale.shop_keeper.full_name %></div>
                  <div class="text-[10px] text-slate-400"><%= sale.shop_keeper.email %></div>
                <% else %>
                  <span class="text-slate-300 italic">System</span>
                <% end %>
              </td>
              <td class="py-4 px-4 text-slate-500">Walk-in Customer</td>
              <td class="py-4 px-4">
                <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-[10px] font-bold <%= payment_badge_class(sale.payment_method) %>">
                  <%= sale.payment_method.humanize %>
                </span>
              </td>
              <td class="py-4 px-4 text-right font-black text-slate-900"><%= number_to_currency(sale.grand_total, unit: "GHS ") %></td>
              <td class="py-4 px-6 text-center text-slate-400"><%= sale.created_at.strftime("%d %b %Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="flex items-center justify-between p-5 border-t border-slate-100 bg-slate-50/30">
      <span class="text-xs text-slate-400 font-bold">
        Showing <%= @sales.offset_value + 1 %>–<%= @sales.offset_value + @sales.length %> of <%= @sales.total_count %>
      </span>
      <div class="kaminari-pagination-container text-xs font-bold">
        <%= paginate @sales %>
      </div>
    </div>
  </div>
</div>