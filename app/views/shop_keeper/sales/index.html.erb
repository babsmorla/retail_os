<% content_for :title, "Sales History" %>
<div class="min-h-screen bg-slate-50/50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
      <div>
        <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Sales History</h1>
        <p class="text-sm text-slate-500 mt-1">View, filter, and export completed store transactions.</p>
      </div>
      <div class="flex items-center gap-3">
        <%= link_to shop_keeper_sales_path(format: :csv, search: params[:search], user_id: params[:user_id], start_date: params[:start_date], end_date: params[:end_date]),
                    class: "inline-flex items-center justify-center gap-2 bg-emerald-50 hover:bg-emerald-100 text-emerald-700 font-bold py-3 px-5 rounded-xl transition text-sm cursor-pointer" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Export CSV
        <% end %>
        <%= link_to new_shop_keeper_sale_path,
                    class: "inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-5 rounded-xl shadow-md shadow-blue-100 transition text-sm cursor-pointer" do %>
          + New Sale
        <% end %>
      </div>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex flex-col justify-center">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Filter Period</p>
        <div class="grid grid-cols-2 gap-2">
          <% ["today", "yesterday", "this_week", "this_month"].each do |p| %>
            <%= link_to p.humanize, shop_keeper_sales_path(period: p), 
                class: "py-2.5 text-center text-xs font-bold rounded-xl transition border #{params[:period] == p ? 'bg-blue-600 text-white border-blue-600 shadow-sm' : 'bg-slate-50 hover:bg-slate-100 text-slate-600 border-transparent'}" %>
          <% end %>
        </div>
      </div>
      <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
        <div class="h-14 w-14 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center shrink-0">
          <span class="text-xl font-extrabold">GH₵</span>
        </div>
        <div>
          <p class="text-xs font-semibold text-slate-400">Total Revenue</p>
          <p class="text-2xl font-black text-slate-900 mt-0.5"><%= number_to_currency(@total_revenue, unit: "GH₵") %></p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
        <div class="h-14 w-14 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center shrink-0">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold text-slate-400">Transactions</p>
          <p class="text-2xl font-black text-slate-900 mt-0.5"><%= @total_transactions %></p>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-3xl border border-slate-100 p-6 shadow-sm">
      <h2 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Search & Filters</h2>
      <%= form_with url: shop_keeper_sales_path, method: :get, local: true, class: "space-y-4" do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div class="flex flex-col">
            <label class="text-xs font-semibold text-slate-500 mb-2">Receipt Number</label>
            <%= text_field_tag :search, params[:search], placeholder: "Search receipt number...", class: "border border-slate-200 rounded-xl px-4 py-2.5 focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 text-sm w-full transition bg-slate-50/50 focus:bg-white" %>
          </div>
          <div class="flex flex-col">
            <label class="text-xs font-semibold text-slate-500 mb-2">Start Date</label>
            <%= date_field_tag :start_date, params[:start_date], class: "border border-slate-200 rounded-xl px-4 py-2.5 focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 text-sm w-full transition bg-slate-50/50 focus:bg-white" %>
          </div>
          <div class="flex flex-col">
            <label class="text-xs font-semibold text-slate-500 mb-2">End Date</label>
            <%= date_field_tag :end_date, params[:end_date], class: "border border-slate-200 rounded-xl px-4 py-2.5 focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 text-sm w-full transition bg-slate-50/50 focus:bg-white" %>
          </div>
          <div class="flex flex-col">
            <label class="text-xs font-semibold text-slate-500 mb-2">Shopkeeper</label>
            <%= select_tag :user_id, options_from_collection_for_select(@shopkeepers, :id, :email, params[:user_id]), include_blank: "All Staff", class: "border border-slate-200 rounded-xl px-4 py-2.5 focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 text-sm w-full bg-slate-50/50 focus:bg-white transition" %>
          </div>
        </div>
        <div class="flex justify-end items-center gap-3 pt-2">
          <%= link_to "Clear Filters", shop_keeper_sales_path, class: "text-xs text-slate-500 hover:text-slate-800 font-bold px-4 py-2" %>
          <button type="submit" class="bg-slate-900 hover:bg-black text-white px-6 py-2.5 rounded-xl font-bold transition text-xs shadow-sm cursor-pointer">Apply Filters</button>
        </div>
      <% end %>
    </div>
    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100">
          <thead class="bg-slate-50/70">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Receipt</th>
              <th class="px-6 py-4 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Date & Time</th>
              <th class="px-6 py-4 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Shopkeeper</th>
              <th class="px-6 py-4 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Payment Method</th>
              <th class="px-6 py-4 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Amount</th>
              <th class="px-6 py-4 text-right text-xs font-bold text-slate-400 uppercase tracking-wider">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50 bg-white">
            <% if @sales.any? %>
              <% @sales.each do |sale| %>
                <tr class="hover:bg-slate-50/60 transition duration-150">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="font-bold text-slate-900"><%= sale.receipt_number %></span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-slate-600 text-sm">
                    <%= sale.created_at.strftime("%d %b %Y %H:%M") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="font-bold text-slate-800 text-sm"><%= sale.shop_keeper&.email&.split('@')&.first&.titleize || "System" %></div>
                    <div class="text-[10px] text-slate-400 font-semibold mt-0.5"><%= sale.shop_keeper&.email %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="inline-flex px-2.5 py-1 rounded-full text-[10px] font-bold bg-slate-100 text-slate-600 border border-slate-200/50">
                      <%= sale.payment_method.to_s.humanize %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap font-extrabold text-slate-900">
                    GH₵<%= number_with_precision(sale.grand_total, precision: 2) %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right">
                    <% if sale.receipt.present? %>
                      <%= link_to shop_keeper_receipt_path(sale.receipt), target: "_blank", class: "inline-flex items-center px-4 py-2 rounded-xl bg-blue-50 text-blue-600 hover:bg-blue-100 text-xs font-bold transition" do %>
                        View Receipt
                      <% end %>
                    <% else %>
                      <span class="text-slate-400 text-xs italic">No Receipt</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="6" class="px-6 py-20 text-center text-slate-400">
                  <div class="text-sm font-semibold">No transactions match the filter criteria.</div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @sales.respond_to?(:total_pages) && @sales.total_pages > 1 %>
        <div class="px-6 py-4 bg-slate-50/50 border-t border-slate-100 flex items-center justify-between">
          <div class="text-xs font-bold text-slate-500">
            Showing Page <%= @sales.current_page %> of <%= @sales.total_pages %>
          </div>
          <div class="flex items-center gap-1.5">
            <%= link_to_unless @sales.first_page?, "Previous", shop_keeper_sales_path(params.permit!.merge(page: @sales.current_page - 1)), class: "px-3 py-1.5 text-xs font-bold text-slate-600 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 transition" %>
            <%= link_to_unless @sales.last_page?, "Next", shop_keeper_sales_path(params.permit!.merge(page: @sales.current_page + 1)), class: "px-3 py-1.5 text-xs font-bold text-slate-600 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 transition" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>