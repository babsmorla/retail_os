<% content_for :title, "New Sale" %>
<div data-controller="cart"
     x-data="{ confirmOpen: false, paymentMethod: 'cash' }" 
     class="min-h-screen bg-slate-50/50 p-6 flex flex-col lg:flex-row gap-6 font-sans antialiased text-slate-800">
  <!-- Left Side: Products & Categories -->
  <div class="flex-1 flex flex-col gap-6">
    <!-- Search Bar -->
    <div class="flex flex-col sm:flex-row gap-3 items-center">
      <%= form_with url: new_shop_keeper_sale_path,
                    method: :get,
                    data: { turbo_frame: "products" },
                    class: "flex-1 w-full flex gap-3" do %>
        <%= hidden_field_tag :category_id, params[:category_id] %>
        <div class="relative flex-1">
          <%= text_field_tag :search,
              params[:search],
              placeholder: "Search products by name or SKU...",
              class: "w-full block bg-white border border-slate-200 rounded-2xl pl-11 pr-4 py-3 text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" %>
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35m0 0A7.5 7.5 0 1 0 6.15 6.15a7.5 7.5 0 0 0 10.5 10.5Z"/>
            </svg>
          </div>
        </div>
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-2xl font-semibold text-sm flex items-center gap-2 transition shadow-sm cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35m0 0A7.5 7.5 0 1 0 6.15 6.15a7.5 7.5 0 0 0 10.5 10.5Z"/>
          </svg>
          Search
        </button>
      <% end %>
    </div>
    <!-- Category Quick Filters -->
    <div class="flex gap-2 overflow-x-auto pb-2">
      <!-- Active state toggle for "All" button -->
      <%= link_to "All", new_shop_keeper_sale_path(search: params[:search]), 
                  class: "px-4 py-2 rounded-xl text-sm font-semibold transition border #{params[:category_id].blank? ? 'bg-blue-600 text-white border-blue-600' : 'bg-white border-slate-200 text-slate-600 hover:bg-slate-50'}" %>
      <% if @categories.any? %>
        <% @categories.each do |category| %>
          <% is_selected = params[:category_id].to_s == category.id.to_s %>
          <%= link_to category.name,
                      new_shop_keeper_sale_path(category_id: category.id, search: params[:search]),
                      class: "px-4 py-2 rounded-xl text-sm font-semibold transition border #{is_selected ? 'bg-blue-600 text-white border-blue-600' : 'bg-white border-slate-200 text-slate-600 hover:bg-slate-50'}" %>
        <% end %>
      <% end %>
    </div>
    <!-- Products Grid Inside Turbo Frame -->
   <%= turbo_frame_tag "products" do %>
  <% if @products.any? %>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      <% @products.each do |product| %>
        <button type="button"
                    data-action="click->cart#add"
          data-product-id="<%= product.id %>"
          data-product-name="<%= product.name %>"
          data-product-price="<%= product.unit_price %>"
          class="bg-white border border-slate-200 hover:border-blue-500 hover:shadow-lg transition-all duration-200 rounded-2xl p-4 flex flex-col items-start text-left relative group cursor-pointer">
          <div class="bg-blue-50/50 group-hover:bg-blue-50 text-blue-600 p-2.5 rounded-xl mb-4 transition duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
            </svg>
          </div>
          <span class="font-bold text-slate-800 text-sm tracking-tight line-clamp-1 mb-0.5"><%= product.name %></span>
          <span class="text-[11px] text-slate-400 font-medium">SKU-<%= product.sku %></span>
          <div class="flex justify-between items-end w-full mt-5">
            <span class="text-blue-600 font-extrabold text-sm tracking-tight">GH₵<%= number_with_precision(product.unit_price, precision: 2) %></span>
            <span class="text-[11px] font-semibold text-slate-400"><%= product.quantity_on_hand %> left</span>
          </div>
        </button>
      <% end %>
    </div>
    <% if @products.respond_to?(:total_pages) && @products.total_pages > 1 %>
      <div class="mt-6 p-4 bg-white border border-slate-100 rounded-2xl flex items-center justify-between shadow-sm">
        <div class="text-xs font-bold text-slate-500">
          Showing Page <%= @products.current_page %> of <%= @products.total_pages %>
        </div>
        <div class="flex items-center gap-1.5">
          <%= link_to_unless @products.first_page?, "Previous", 
                                 new_shop_keeper_sale_path(params.permit!.merge(page: @products.current_page - 1)), 
                                 class: "px-4 py-2 text-xs font-bold text-slate-600 bg-slate-50 border border-slate-200 rounded-xl hover:bg-slate-100 transition cursor-pointer" %>
          <%= link_to_unless @products.last_page?, "Next", 
                                 new_shop_keeper_sale_path(params.permit!.merge(page: @products.current_page + 1)), 
                                 class: "px-4 py-2 text-xs font-bold text-slate-600 bg-slate-50 border border-slate-200 rounded-xl hover:bg-slate-100 transition cursor-pointer" %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="bg-white border border-slate-100 rounded-3xl p-12 text-center text-slate-400">
      <p class="text-sm font-semibold">No available items found in this section.</p>
    </div>
  <% end %>
<% end %>
  </div>
  <!-- Right Side: Shopping Cart Sidebar -->
  <div id="shopping-cart-sidebar" data-turbo-permanent class="w-full lg:w-[380px] shrink-0">
    <div class="bg-white border border-slate-200 rounded-3xl p-5 shadow-sm sticky top-6 flex flex-col min-h-[calc(100vh-3rem)] justify-between">
      <div>
        <div class="flex justify-between items-center pb-4 border-b border-slate-100">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-blue-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
            </svg>
            <h2 class="text-base font-bold text-slate-800">Cart</h2>
            <span data-cart-target="count" class="bg-blue-600 text-white text-xs font-bold px-2 py-0.5 rounded-full">0</span>
          </div>
          <button type="button" data-action="click->cart#clear" class="text-xs font-bold text-red-500 hover:text-red-600 flex items-center gap-1 transition cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
            Clear
          </button>
        </div>
        <div class="mt-4 relative">
          <input type="text" placeholder="Add customer (optional)" class="w-full bg-slate-50 border border-slate-100 rounded-xl pl-10 pr-4 py-2.5 text-xs text-slate-600 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-200">
          <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
            </svg>
          </div>
        </div>
        <div data-cart-target="items" class="mt-4 divide-y divide-slate-100 max-h-[300px] overflow-y-auto pr-1"></div>
      </div>
      <div class="mt-6 border-t border-slate-100 pt-4">
        <div class="space-y-2.5 text-xs font-semibold">
          <div class="flex justify-between text-slate-400">
            <span>Subtotal</span>
            <span data-cart-target="subtotal">GH₵ 0.00</span>
          </div>
          <div class="flex justify-between text-slate-400">
            <span>Tax</span>
            <span data-cart-target="tax">GH₵ 0.00</span>
          </div>
          <div class="border-t border-slate-100 my-4"></div>
          <div class="flex justify-between items-center py-1">
            <span class="text-sm font-bold text-slate-800">Total</span>
            <span class="text-xl font-black text-blue-600 tracking-tight">GH₵ <span data-cart-target="total">0.00</span></span>
          </div>
        </div>
        <%= form_with model: @sale, url: shop_keeper_sales_path, class: "mt-6 space-y-4", data: { turbo: false } do |form| %>
          <% if @sale.errors.any? %>
            <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-xl mb-6">
              <h3 class="font-bold text-sm mb-1">Please fix the following errors:</h3>
              <ul class="list-disc pl-5 text-xs">
                <% @sale.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <div data-cart-target="fields"></div>
          <%= form.hidden_field :payment_method, "x-model": "paymentMethod" %>
          <!-- Payment Method Selection -->
          <div>
            <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2.5">Payment Method</span>
            <div class="grid grid-cols-3 gap-2">
              <button type="button" 
                      @click="paymentMethod = 'cash'" 
                      :class="paymentMethod === 'cash' ? 'border-blue-500 bg-blue-50/40 text-blue-600' : 'border-slate-200 text-slate-600 hover:bg-slate-50'" 
                      class="flex flex-col items-center justify-center p-3 border rounded-2xl transition-all duration-150 text-center cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5h16.5M5.25 9h13.5m-15 4.5h16.5m-15 4.5h16.5m-15 0a2.25 2.25 0 0 1-2.25-2.25V6.75A2.25 2.25 0 0 1 3.75 4.5h16.5a2.25 2.25 0 0 1 2.25 2.25v10.5a2.25 2.25 0 0 1-2.25 2.25H3.75Z" />
                </svg>
                <span class="text-[11px] font-bold mt-1.5">Cash</span>
              </button>
              <button type="button" 
                      @click="paymentMethod = 'card'" 
                      :class="paymentMethod === 'card' ? 'border-blue-500 bg-blue-50/40 text-blue-600' : 'border-slate-200 text-slate-600 hover:bg-slate-50'" 
                      class="flex flex-col items-center justify-center p-3 border rounded-2xl transition-all duration-150 text-center cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-6.188-12h14.376a1.125 1.125 0 0 1 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125H3.188A1.125 1.125 0 0 1 2.063 17.625V4.375c0-.621.504-1.125 1.125-1.125Z" />
                </svg>
                <span class="text-[11px] font-bold mt-1.5">Card</span>
              </button>
              <button type="button" 
                      @click="paymentMethod = 'mobile_money'" 
                      :class="paymentMethod === 'mobile_money' ? 'border-blue-500 bg-blue-50/40 text-blue-600' : 'border-slate-200 text-slate-600 hover:bg-slate-50'" 
                      class="flex flex-col items-center justify-center p-3 border rounded-2xl transition-all duration-150 text-center cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
                </svg>
                <span class="text-[11px] font-bold mt-1.5">MoMo</span>
              </button>
            </div>
          </div>
          <!-- Confirm Action -->
          <div class="pt-2">
            <button type="button" 
                    @click="confirmOpen = true" 
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 px-4 rounded-2xl transition duration-150 flex items-center justify-center gap-2 shadow-lg shadow-blue-500/10 cursor-pointer text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              Confirm Sale
            </button>
            <span class="block text-center text-[10px] text-slate-400 mt-3 font-semibold">Sale cannot be edited after confirmation</span>
          </div>
          <!-- Confirmation Modal Overlay -->
          <div x-show="confirmOpen" 
               x-transition:enter="transition ease-out duration-300"
               x-transition:enter-start="opacity-0 scale-95"
               x-transition:enter-end="opacity-100 scale-100"
               x-transition:leave="transition ease-in duration-200"
               x-transition:leave-start="opacity-100 scale-100"
               x-transition:leave-end="opacity-0 scale-95"
               class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center z-50 p-4" 
               style="display: none;">
            <div class="bg-white rounded-[24px] p-6 max-w-sm w-full shadow-2xl border border-slate-100/50">
              <div class="flex items-start gap-4">
                <div class="bg-amber-50 text-amber-500 p-2.5 rounded-2xl shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                  </svg>
                </div>
                <div>
                  <h2 class="text-base font-extrabold text-slate-800">Confirm Sale?</h2>
                  <p class="text-xs text-slate-400 font-semibold mt-0.5">This action cannot be undone.</p>
                  <p class="text-xs text-slate-500 mt-3.5 leading-relaxed font-medium">
                    Once confirmed, this sale cannot be edited or cancelled. Proceed only when you are sure.
                  </p>
                </div>
              </div>
              <div class="mt-6 flex justify-end gap-3">
                <button type="button" 
                        @click="confirmOpen = false" 
                        class="flex-1 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 font-bold py-2.5 px-4 rounded-xl transition text-xs text-center cursor-pointer">
                  Cancel
                </button>
                <button type="submit" 
                        class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 px-4 rounded-xl transition text-xs text-center cursor-pointer">
                  Yes, Confirm
                </button>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>