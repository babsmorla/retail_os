<div class="p-6">
  <h1 class="text-2xl font-bold mb-6">Sales Analytics</h1>
  <div class="flex space-x-4 mb-8">
    <% ["today", "yesterday", "this_week", "this_month"].each do |p| %>
      <%= link_to p.humanize, shop_keeper_sales_analytics_path(period: p), 
          class: "px-4 py-2 rounded-lg #{params[:period] == p ? 'bg-blue-600 text-white' : 'bg-white border'}" %>
    <% end %>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white p-6 rounded-lg shadow">
      <p class="text-slate-500">Total Revenue</p>
      <h2 class="text-3xl font-bold"><%= number_to_currency(@total_revenue) %></h2>
    </div>
    <div class="bg-white p-6 rounded-lg shadow">
      <p class="text-slate-500">Transactions</p>
      <h2 class="text-3xl font-bold"><%= @total_transactions %></h2>
    </div>
    <div class="bg-white p-6 rounded-lg shadow">
      <p class="text-slate-500">Avg. Order Value</p>
      <h2 class="text-3xl font-bold"><%= number_to_currency(@average_order_value) %></h2>
    </div>
  </div>
  <table class="w-full bg-white shadow rounded-lg overflow-hidden">
  </table>
</div>