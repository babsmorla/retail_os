<% content_for :title, "Inventory Products" %>
<div class="p-6 space-y-6 bg-slate-50 min-h-screen">
  <div class="flex flex-col md:flex-row md:justify-between md:items-center gap-4">
  <div>
    <h1 class="text-3xl font-bold text-slate-900">Inventory Products</h1>
    <p class="text-slate-500">Manage stock levels, pricing, and product details</p>
  </div>
  <div class="flex gap-3">
    <%= link_to "View Archive", archived_shop_keeper_products_path, 
        class: "px-5 py-3 rounded-xl bg-white border border-slate-200 font-semibold text-slate-500 hover:text-slate-700 hover:bg-slate-50" %>
    <%= link_to "Export CSV", shop_keeper_products_path(format: :csv), 
        class: "px-5 py-3 rounded-xl bg-white border border-slate-200 font-semibold text-slate-700 hover:bg-slate-50" %>
    <%= link_to "+ New Product", new_shop_keeper_product_path, 
        class: "bg-blue-600 text-white px-5 py-3 rounded-xl font-semibold hover:bg-blue-700 shadow-sm" %>
  </div>
</div>

  <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 space-y-6">
    <%= form_with url: shop_keeper_products_path, method: :get, class: "relative" do |f| %>
      <div class="relative flex items-center">
        <svg class="absolute left-4 w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <%= f.text_field :search, value: params[:search], placeholder: "Search by name or SKU...", class: "w-full pl-12 pr-16 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all text-slate-700" %>
        <div class="absolute right-4 px-2 py-1 bg-white border border-slate-200 rounded-lg text-[10px] font-bold text-slate-400">⌘F</div>
      </div>
    <% end %>

    <div class="flex items-center gap-2 overflow-x-auto pb-1">
      <%= link_to "All", shop_keeper_products_path, class: "px-6 py-2.5 rounded-xl font-bold text-sm transition-all #{params[:category_id].blank? ? 'bg-blue-600 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}" %>
      <% Category.all.each do |cat| %>
        <%= link_to cat.name, shop_keeper_products_path(category_id: cat.id), class: "px-6 py-2.5 rounded-xl font-medium text-sm transition-all whitespace-nowrap #{params[:category_id].to_i == cat.id ? 'bg-blue-600 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}" %>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="overflow-x-auto max-h-[60vh]">
      <table class="w-full text-left border-collapse">
        <thead class="bg-slate-50 sticky top-0 z-10 border-b border-slate-100">
          <tr>
            <th class="p-4 text-xs font-bold text-slate-400 uppercase">S/N</th>
            <th class="p-4 text-xs font-bold text-slate-400 uppercase">Details</th>
            <th class="p-4 text-xs font-bold text-slate-400 uppercase">SKU</th>
            <th class="p-4 text-xs font-bold text-slate-400 uppercase">Category</th>
            <th class="p-4 text-xs font-bold text-slate-400 uppercase">Pricing</th>
            <th class="p-4 text-xs font-bold text-slate-400 uppercase">Stock</th>
            <th class="p-4 text-xs font-bold text-slate-400 uppercase text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @products.each_with_index do |product, index| %>
          <% next if product.nil? %>
            <tr class="hover:bg-slate-50 transition">
              <td class="p-4 text-sm text-slate-400"><%= index + 1 %></td>
              <td class="p-4 font-bold text-slate-900"><%= product.name %></td>
              <td class="p-4 font-mono text-xs text-slate-500"><%= product.sku || "N/A" %></td>
              <td class="p-4 text-sm text-slate-600"><%= product.category&.name || "—" %></td>
              <td class="p-4">
                <div class="text-sm font-semibold">GH₵ <%= product.unit_price %></div>
                <div class="text-[10px] text-slate-400">Cost: GH₵ <%= product.cost_price %></div>
              </td>
              <td class="p-4">
                <% if product.quantity_on_hand <= product.low_stock_threshold.to_i %>
                  <span class="px-2.5 py-1 rounded-lg bg-red-50 text-red-700 text-xs font-bold border border-red-100">Low (<%= product.quantity_on_hand %>)</span>
                <% else %>
                  <span class="px-2.5 py-1 rounded-lg bg-green-50 text-green-700 text-xs font-bold border border-green-100"><%= product.quantity_on_hand %></span>
                <% end %>
              </td>
           <td class="p-4 text-right flex justify-end gap-3">
  <% if current_user&.admin? %>
    <%= link_to "Edit", edit_shop_keeper_product_path(product), 
                class: "text-blue-600 font-semibold text-sm hover:underline" %>
   <%= button_to "Deactivate", shop_keeper_product_path(product), 
    method: :delete, 
    data: { turbo_confirm: "Are you sure you want to deactivate this product?" },
    class: "text-red-600 font-semibold text-sm hover:underline border-none bg-transparent p-0 cursor-pointer",
    form: { style: "display: inline-block;" } 
%>
  <% end %>
</td>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @products.empty? %>
      <div class="p-12 text-center text-slate-400">No products found.</div>
    <% end %>
  </div>
</div>