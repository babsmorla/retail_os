<div class="p-6">
  <!-- Flex container for Header and Button -->
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Team Members</h1>
    <%= link_to "Add New User", new_shop_keeper_staff_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium transition" %>
  </div>
  <table class="w-full bg-white rounded-lg shadow">
    <thead>
      <tr class="text-left border-b">
        <th class="p-4">Name</th>
        <th class="p-4">Email</th>
        <th class="p-4">Role</th>
        <th class="p-4">Store Access</th>
      </tr>
    </thead>
    <tbody>
      <% @staff.each do |user| %>
        <tr class="border-b">
          <td class="p-4"><%= user.full_name %></td>
          <td class="p-4"><%= user.email %></td>
          <td class="p-4 capitalize"><%= user.role&.humanize %></td>
          <td class="p-4 text-xs font-bold text-blue-600">
            <%= user.memberships.includes(:store).map { |m| m.store&.name }.compact.join(', ') %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>