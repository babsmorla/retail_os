<% content_for :title, "Accounting & Financials" %>
<!-- Scoped CSS to style the Rails Kaminari Pagination beautifully -->
<div class="space-y-8 p-8 max-w-[1600px] mx-auto bg-white min-h-screen text-slate-800">
  <!-- ================= HEADER SECTION ================= -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 pb-6 border-b border-slate-100">
    <div>
      <h1 class="text-3xl font-black text-slate-900 tracking-tight">
        Accounting
      </h1>
      <p class="text-slate-500 mt-1.5 text-sm font-medium">
        Manage your finances and monitor business performance.
      </p>
    </div>
    <div class="flex gap-3">
      <button class="px-5 py-2.5 bg-white text-slate-700 border border-slate-200 rounded-xl font-bold shadow-sm hover:bg-slate-50 transition text-xs">
        System Settings
      </button>
      <button class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-bold shadow-sm transition text-xs">
        Print Report
      </button>
    </div>
  </div>
  <!-- ================= TOP KPI CARDS (4-COL GRID) ================= -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Total Revenue Card -->
    <div class="bg-white border border-slate-200/60 rounded-2xl p-6 shadow-sm transition-shadow hover:shadow-md">
      <div class="flex items-center justify-between">
        <span class="text-[11px] font-extrabold text-slate-400 uppercase tracking-wider">Total Revenue</span>
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
      </div>
      <div class="mt-4">
        <h3 class="text-2xl font-black text-slate-950 tracking-tight">
          <%= number_to_currency(@total_revenue, unit: "GHS ", precision: 2) %>
        </h3>
        <div class="mt-2.5 flex items-center gap-1.5 text-xs font-bold text-emerald-600">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.5 4.5 8.25-8.25M21.75 8.25H16.5V13.5" />
          </svg>
          <span>All sales recorded</span>
        </div>
      </div>
    </div>
    <!-- Today's Revenue Card -->
    <div class="bg-white border border-slate-200/60 rounded-2xl p-6 shadow-sm transition-shadow hover:shadow-md">
      <div class="flex items-center justify-between">
        <span class="text-[11px] font-extrabold text-slate-400 uppercase tracking-wider">Today's Revenue</span>
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-50 text-amber-600">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
      </div>
      <div class="mt-4">
        <h3 class="text-2xl font-black text-amber-600 tracking-tight">
          <%= number_to_currency(@today_revenue, unit: "GHS ", precision: 2) %>
        </h3>
        <div class="mt-2.5 flex items-center gap-1.5 text-xs font-bold text-amber-600">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.5 4.5 8.25-8.25M21.75 8.25H16.5V13.5" />
          </svg>
          <span>Today's performance</span>
        </div>
      </div>
    </div>
    <!-- Expenses Card -->
    <div class="bg-white border border-slate-200/60 rounded-2xl p-6 shadow-sm transition-shadow hover:shadow-md">
      <div class="flex items-center justify-between">
        <span class="text-[11px] font-extrabold text-slate-400 uppercase tracking-wider">Expenses</span>
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-red-50 text-red-600">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
          </svg>
        </div>
      </div>
      <div class="mt-4">
        <h3 class="text-2xl font-black text-red-600 tracking-tight">GHS 0.00</h3>
        <div class="mt-2.5 flex items-center gap-1.5 text-xs font-bold text-red-500">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" />
          </svg>
          <span>No expenses recorded</span>
        </div>
      </div>
    </div>
    <!-- Net Profit Card -->
    <div class="bg-white border border-slate-200/60 rounded-2xl p-6 shadow-sm transition-shadow hover:shadow-md">
      <div class="flex items-center justify-between">
        <span class="text-[11px] font-extrabold text-slate-400 uppercase tracking-wider">Net Profit</span>
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.5 4.5 8.25-8.25M21.75 8.25H16.5V13.5" />
          </svg>
        </div>
      </div>
      <div class="mt-4">
        <h3 class="text-2xl font-black text-emerald-600 tracking-tight">
          <%= number_to_currency(@total_revenue, unit: "GHS ", precision: 2) %>
        </h3>
        <div class="mt-2.5 flex items-center gap-1.5 text-xs font-bold text-emerald-600">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.5 4.5 8.25-8.25M21.75 8.25H16.5V13.5" />
          </svg>
          <span>All sales recorded</span>
        </div>
      </div>
    </div>
  </div>
  <!-- ================= MAIN DOUBLE COLUMN GRID ================= -->
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
    <!-- LEFT PANEL: CHART, PAYMENT METHOD CARDS, AND TABLE LEDGER -->
    <div class="xl:col-span-2 space-y-8">
      <!-- REVENUE CHART CARD -->
      <div class="bg-white border border-slate-200/60 rounded-2xl p-6 shadow-sm">
        <h3 class="text-sm font-bold text-slate-900 mb-4">Revenue Overview</h3>
        <div class="relative w-full h-[240px]">
          <canvas id="revenueChart" data-chart='<%= @revenue_chart.to_json %>'></canvas>
        </div>
      </div>
      <!-- PAYMENT CHANNEL SPLIT CARDS (3-COL GRID) -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Cash Card -->
        <div class="bg-white border border-slate-200/60 rounded-2xl p-5 shadow-sm flex items-center justify-between">
          <div class="space-y-1">
            <span class="block text-xs font-bold text-slate-400">Cash Sales</span>
            <h4 class="text-lg font-black text-slate-900 tracking-tight">
              <%= number_to_currency(@cash_sales, unit: "GHS ", precision: 2) %>
            </h4>
            <span class="block text-[10px] font-bold text-slate-400">Cash received</span>
          </div>
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5h16.5M5.25 7.5h13.5m-15 3h16.5m-18 3h19.5M4.5 16.5h15" />
            </svg>
          </div>
        </div>
        <!-- Card Payments Card -->
        <div class="bg-white border border-slate-200/60 rounded-2xl p-5 shadow-sm flex items-center justify-between">
          <div class="space-y-1">
            <span class="block text-xs font-bold text-slate-400">Card Payments</span>
            <h4 class="text-lg font-black text-slate-900 tracking-tight">
              <%= number_to_currency(@card_sales, unit: "GHS ", precision: 2) %>
            </h4>
            <span class="block text-[10px] font-bold text-slate-400">Card performance</span>
          </div>
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
            </svg>
          </div>
        </div>
        <!-- Mobile Money Card -->
        <div class="bg-white border border-slate-200/60 rounded-2xl p-5 shadow-sm flex items-center justify-between">
          <div class="space-y-1">
            <span class="block text-xs font-bold text-slate-400">Mobile Money</span>
            <h4 class="text-lg font-black text-slate-900 tracking-tight">
              <%= number_to_currency(@mobile_money_sales, unit: "GHS ", precision: 2) %>
            </h4>
            <span class="block text-[10px] font-bold text-slate-400">MoMo payments</span>
          </div>
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-purple-50 text-purple-600">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
            </svg>
          </div>
        </div>
      </div>
      <!-- TRANSACTION LEDGER TABLE (ONLY CONTAINER FOR EXPORT & REPORT GENERATION) -->
      <div class="bg-white border border-slate-200/60 rounded-2xl shadow-sm overflow-hidden">
        <!-- Table Header Panel -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 p-5 border-b border-slate-100">
          <h3 class="text-sm font-black text-slate-900 tracking-tight">Recent Transactions</h3>
          <div class="flex items-center gap-2.5 w-full sm:w-auto">
            <div class="bg-white border border-slate-200 rounded-2xl p-6 text-center">
              <%= link_to "View All Transactions →", history_shop_keeper_sales_path, 
      class: "text-blue-600 font-bold hover:underline" %>
            </div>
          </div>
        </div>
        <!-- Scrollable Table -->
        <div class="overflow-x-auto w-full">
          <table class="w-full min-w-[700px] border-collapse text-left text-xs font-semibold">
            <thead>
              <tr class="bg-slate-50/75 border-b border-slate-100 text-[10px] uppercase font-bold text-slate-400 tracking-wider">
                <th class="py-3.5 px-6">Receipt</th>
                <th class="py-3.5 px-4">Shop Keeper</th>
                <th class="py-3.5 px-4">Payment</th>
                <th class="py-3.5 px-4 text-right">Amount</th>
                <th class="py-3.5 px-6 text-center">Date</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-slate-700">
              <% @recent_sales.each do |sale| %>
                <tr class="hover:bg-slate-50/50 transition-colors duration-150">
                  <!-- Receipt ID -->
                  <td class="py-3.5 px-6 font-bold text-slate-900">
                    <%= sale.receipt_number || sale.id %>
                  </td>
                  <!-- Customer -->
                  <td class="py-4 px-4 text-slate-600 font-medium">
                    <% if sale.shop_keeper %>
                      <div class="font-bold"><%= sale.shop_keeper.full_name %></div>
                      <div class="text-[10px] text-slate-400"><%= sale.shop_keeper.email %></div>
                    <% else %>
                      <span class="text-slate-300 italic">System</span>
                    <% end %>
                  </td>
                  <!-- Payment Badge -->
                  <td class="py-3.5 px-4">
                    <% if sale.payment_method.downcase == 'cash' %>
                      <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-0.5 text-[10px] font-bold text-emerald-600">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                        <%= sale.payment_method.humanize %>
                      </span>
                    <% elsif sale.payment_method.downcase == 'card' %>
                      <span class="inline-flex items-center gap-1 rounded-full bg-blue-50 px-2.5 py-0.5 text-[10px] font-bold text-blue-600">
                        <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                        <%= sale.payment_method.humanize %>
                      </span>
                    <% else %>
                      <span class="inline-flex items-center gap-1 rounded-full bg-purple-50 px-2.5 py-0.5 text-[10px] font-bold text-purple-600">
                        <span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>
                        <%= sale.payment_method.humanize %>
                      </span>
                    <% end %>
                  </td>
                  <!-- Amount -->
                  <td class="py-3.5 px-4 text-right font-black text-slate-900">
                    <%= number_to_currency(sale.grand_total, unit: "GHS ") %>
                  </td>
                  <!-- Date -->
                  <td class="py-3.5 px-6 text-center text-slate-400 font-medium">
                    <%= sale.created_at.strftime("%d %b %Y") %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <!-- Custom Styled Kaminari Pagination Footer -->
      </div>
    </div>
    <!-- RIGHT SIDE PANEL: METRICS GRAPHICS AND ACCESSIBLE QUICK ACTIONS -->
    <div class="space-y-8">
      <!-- PAYMENT BREAKDOWN CARD -->
      <div class="bg-white border border-slate-200/60 rounded-2xl p-6 shadow-sm">
        <h3 class="text-sm font-black text-slate-900 mb-5 tracking-tight">Payment Breakdown</h3>
        <div class="space-y-5">
          <!-- Cash Progress -->
          <div>
            <div class="flex justify-between font-bold text-xs">
              <span class="text-slate-600">Cash</span>
              <span class="text-slate-900">
                <%= number_to_currency(@cash_sales, unit: "GHS ") %>
              </span>
            </div>
            <div class="h-2 bg-slate-100 rounded-full mt-2 overflow-hidden">
              <div class="h-full bg-emerald-500 rounded-full w-3/4"></div>
            </div>
          </div>
          <!-- Mobile Money Progress -->
          <div>
            <div class="flex justify-between font-bold text-xs">
              <span class="text-slate-600">Mobile Money</span>
              <span class="text-slate-900">
                <%= number_to_currency(@mobile_money_sales, unit: "GHS ") %>
              </span>
            </div>
            <div class="h-2 bg-slate-100 rounded-full mt-2 overflow-hidden">
              <div class="h-full bg-purple-500 rounded-full w-1/2"></div>
            </div>
          </div>
          <!-- Card Progress -->
          <div>
            <div class="flex justify-between font-bold text-xs">
              <span class="text-slate-600">Card</span>
              <span class="text-slate-900">
                <%= number_to_currency(@card_sales, unit: "GHS ") %>
              </span>
            </div>
            <div class="h-2 bg-slate-100 rounded-full mt-2 overflow-hidden">
              <div class="h-full bg-blue-500 rounded-full w-1/3"></div>
            </div>
          </div>
        </div>
      </div>
      <!-- TOP SELLING PRODUCTS CARD -->
      <div class="bg-white border border-slate-200/60 rounded-2xl p-6 shadow-sm">
        <h3 class="text-sm font-black text-slate-900 mb-5 tracking-tight">Top Selling Products</h3>
        <div class="space-y-3">
          <% @top_products.each do |name, qty| %>
            <div class="flex justify-between items-center py-2 border-b border-slate-50 last:border-0 text-xs">
              <span class="font-bold text-slate-600">
                <%= name %>
              </span>
              <span class="font-extrabold text-slate-800 bg-slate-50 px-2.5 py-1 rounded-lg border border-slate-100">
                <%= qty %> sold
              </span>
            </div>
          <% end %>
        </div>
      </div>
      <!-- FINANCIAL SUMMARY CARD -->
      <div class="bg-white border border-slate-200/60 rounded-2xl p-6 shadow-sm">
        <h3 class="text-sm font-black text-slate-900 mb-5 tracking-tight">Financial Summary</h3>
        <table class="w-full text-xs font-semibold">
          <tbody>
            <tr>
              <td class="py-2.5 text-slate-500">Revenue</td>
              <td class="text-right font-black text-slate-900">
                <%= number_to_currency(@total_revenue, unit: "GHS ") %>
              </td>
            </tr>
            <tr>
              <td class="py-2.5 text-slate-500">Expenses</td>
              <td class="text-right font-black text-slate-900">GHS 0.00</td>
            </tr>
            <tr class="border-t border-slate-100">
              <td class="py-3.5 font-bold text-slate-900">Net Profit</td>
              <td class="text-right font-black text-emerald-600 text-sm">
                <%= number_to_currency(@total_revenue, unit: "GHS ") %>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <!-- QUICK ACTIONS CARD (EXCLUDES REPETITIVE ACTION DUPLICATIONS) -->
      <div class="bg-white border border-slate-200/60 rounded-2xl p-6 shadow-sm">
        <h3 class="text-sm font-black text-slate-900 mb-4 tracking-tight">Quick Actions</h3>
        <div class="grid gap-2.5 text-xs font-bold">
          <button class="w-full py-2.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white shadow-sm transition">
            Create Expense
          </button>
          <button class="w-full py-2.5 rounded-xl border border-slate-200 bg-white text-slate-700 hover:bg-slate-50 transition">
            Print Statement
          </button>
        </div>
      </div>
    </div>
  </div>
</div>