<div class="p-6 bg-slate-50 min-h-screen">
  <h1 class="text-2xl font-bold mb-6 text-slate-800">Store Reports</h1>
  <%= form_with url: shop_keeper_reports_path, method: :get, class: "bg-white p-6 rounded-xl shadow-sm border border-slate-200 mb-8" do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-end">
      <div class="flex flex-col">
        <label class="text-xs font-semibold text-slate-500 uppercase mb-2">Specific Date</label>
        <%= f.date_field :specific_date, value: params[:specific_date], class: "border-slate-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      <div class="md:col-span-2 flex flex-col">
        <label class="text-xs font-semibold text-slate-500 uppercase mb-2">Or Select Period</label>
        <div class="flex gap-2">
          <% ["today", "yesterday", "this_week", "this_month"].each do |p| %>
            <%= link_to p.humanize, shop_keeper_reports_path(period: p), 
                class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors #{params[:period] == p || (params[:period].nil? && params[:specific_date].blank? && p == 'today') ? 'bg-blue-600 text-white' : 'bg-white border border-slate-300 text-slate-600 hover:bg-slate-50'}" %>
          <% end %>
        </div>
      </div>
      <div class="flex flex-col">
        <%= f.text_field :search, value: params[:search], placeholder: "Receipt #...", class: "border-slate-300 rounded-lg shadow-sm" %>
      </div>
    </div>
    <div class="mt-4 flex gap-3">
      <%= f.submit "Apply Filters", class: "bg-slate-800 text-white px-6 py-2 rounded-lg font-medium hover:bg-slate-900 transition" %>
      <%= link_to "Reset", shop_keeper_reports_path, class: "px-4 py-2 border border-slate-300 rounded-lg text-slate-600 hover:bg-slate-50" %>
    </div>
  <% end %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
      <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">Total Revenue</p>
      <p class="text-3xl font-bold text-slate-900 mt-1"><%= number_to_currency(@total_revenue) %></p>
    </div>
    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
      <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">Total Transactions</p>
      <p class="text-3xl font-bold text-slate-900 mt-1"><%= @total_transactions %></p>
    </div>
  </div>
  <div class="bg-white shadow-sm border border-slate-200 rounded-xl overflow-hidden">
    <table class="w-full text-left">
      <thead class="bg-slate-50 border-b border-slate-200">
        <tr>
          <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase">Receipt #</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase">Total</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase">Cashier</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase">Date/Time</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% if @sales.any? %>
          <% @sales.each do |sale| %>
            <tr class="hover:bg-slate-50 transition">
              <td class="px-6 py-4 text-sm font-medium text-slate-900"><%= sale.receipt_number %></td>
              <td class="px-6 py-4 text-sm text-slate-600"><%= number_to_currency(sale.grand_total) %></td>
              <td class="px-6 py-4 text-sm text-slate-600"><%= sale.shop_keeper&.full_name || "N/A" %></td>
              <td class="px-6 py-4 text-sm text-slate-500"><%= sale.created_at.strftime("%b %d, %Y %I:%M %p") %></td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="px-6 py-8 text-center text-slate-500">No sales found for the selected criteria.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>