<div class="min-h-screen flex flex-col md:flex-row bg-white font-sans text-gray-900">
  <!-- Left Side: Login Form Column -->
  <div class="w-full md:w-1/2 flex flex-col justify-between p-8 md:p-16 lg:p-24 max-w-xl mx-auto md:max-w-none">
    <!-- Header Logo -->
    <div class="flex items-center gap-2 mb-12">
      <!-- RetailOS Icon Container -->
      <div class="bg-blue-600 text-white p-2 rounded-xl flex items-center justify-center shadow-sm shadow-blue-500/20">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h2.64c1.3 0 2.36-1.06 2.36-2.36V10.36M18 21V10.36M12 3.3l8.64 5.2a1.2 1.2 0 0 1 .56 1.02V18.6M12 3.3L3.36 8.5A1.2 1.2 0 0 0 2.8 9.52V18.6M12 3.3v17.7" />
        </svg>
      </div>
      <span class="text-xl font-bold text-slate-900 tracking-tight">RetailOS</span>
    </div>
    <!-- Center Content Form -->
    <div class="w-full max-w-sm mx-auto md:mx-0 my-auto">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 mb-2">Welcome back</h1>
      <p class="text-gray-500 text-sm mb-8">Sign in to your account to continue</p>
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <!-- Email Field -->
        <div>
          <%= f.label :email, "Email address", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <div class="relative rounded-lg shadow-sm">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </div>
            <%= f.email_field :email,
                             autofocus: true,
                             autocomplete: "email",
                             placeholder: "you@example.com",
                             class: "block w-full pl-10 pr-3 py-2.5 bg-gray-50/50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm placeholder-gray-400" %>
          </div>
        </div>
        <!-- Password Field -->
        <div>
          <div class="flex justify-between items-center mb-1.5">
            <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
            <% if respond_to?(:new_password_path) %>
              <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-sm font-medium text-blue-600 hover:text-blue-700" %>
            <% else %>
              <a href="#" class="text-sm font-medium text-blue-600 hover:text-blue-700">Forgot password?</a>
            <% end %>
          </div>
          <div class="relative rounded-lg shadow-sm">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
              </svg>
            </div>
            <%= f.password_field :password,
                                autocomplete: "current-password",
                                placeholder: "••••••••",
                                class: "block w-full pl-10 pr-10 py-2.5 bg-gray-50/50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm placeholder-gray-400" %>
            <div class="absolute inset-y-0 right-0 pr-3 flex items-center cursor-pointer text-gray-400 hover:text-gray-600">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 1-4.243-4.243m4.242 4.242L9.88 9.88" />
              </svg>
            </div>
          </div>
        </div>
        <!-- Remember Me Field -->
        <div class="flex items-center">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500 bg-gray-50" %>
          <%= f.label :remember_me, "Keep me signed in", class: "ml-2 block text-sm text-gray-700" %>
        </div>
        <!-- Submit Button -->
        <div>
          <%= f.button class: "w-full flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-4 rounded-lg transition duration-150 ease-in-out shadow-sm" do %>
            Sign in to RetailOS <span>&rarr;</span>
          <% end %>
        </div>
      <% end %>
      <!-- Divider -->
      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center" aria-hidden="true">
          <div class="w-full border-t border-gray-200"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="bg-white px-3 text-gray-400 text-xs tracking-wide">or continue with</span>
        </div>
      </div>
      <!-- SSO Alternative Button -->
      <button class="w-full flex items-center justify-center gap-2 border border-gray-200 bg-gray-50/30 hover:bg-gray-50 text-gray-700 font-medium py-2.5 px-4 rounded-lg transition duration-150 ease-in-out text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-gray-500">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-.778.099-1.533.284-2.253" />
        </svg>
       <%= link_to "Sign Up Your Shop", signup_path %>
      </button>
    </div>
    <!-- Help Footer Hint -->
    <div class="text-center md:text-left mt-8">
      <p class="text-xs text-gray-400">Having trouble? Contact your system administrator.</p>
    </div>
  </div>
  <!-- Right Side: Marketing Column -->
  <div class="hidden md:flex  bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 relative items-center justify-center p-16 overflow-hidden">
    <!-- Abstract Ambient Background Shapes -->
    <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-blue-900/20 rounded-full blur-3xl"></div>
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-indigo-900/20 rounded-full blur-3xl"></div>
    <div class="z-10 text-center max-w-md w-full flex flex-col items-center">
      <!-- Showcase Image Card Wrapper -->
      <div class="bg-white/10 backdrop-blur-md p-4 rounded-2xl shadow-2xl border border-white/10 mb-8 w-full max-w-sm">
        <div class="aspect-[4/3] rounded-xl overflow-hidden bg-slate-800 relative">
          <!-- Placeholder or direct asset path for the store image -->
          <img src="https://images.unsplash.com/photo-1555529669-e69e7aa0ba9a?auto=format&fit=crop&q=80&w=600" alt="Retail Store Showcase" class="w-full h-full object-cover object-center opacity-90" />
        </div>
      </div>
      <!-- Copy Typography -->
      <h2 class="text-2xl lg:text-3xl font-bold text-white mb-3 tracking-tight">Your store, fully digital.</h2>
      <p class="text-slate-400 text-sm leading-relaxed mb-10 px-4">
        Manage sales, inventory, and accounting — all in one place. Built for speed.
      </p>
      <!-- Feature Pill Badges -->
      <div class="flex items-center gap-6 text-slate-300">
        <div class="flex flex-col items-center gap-1.5">
          <div class="p-2.5 bg-white/5 border border-white/10 rounded-xl">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-blue-400">
              <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
            </svg>
          </div>
          <span class="text-xs font-medium tracking-wide">Fast POS</span>
        </div>
        <div class="flex flex-col items-center gap-1.5">
          <div class="p-2.5 bg-white/5 border border-white/10 rounded-xl">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-blue-400">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.286Z" />
            </svg>
          </div>
          <span class="text-xs font-medium tracking-wide">Secure</span>
        </div>
        <div class="flex flex-col items-center gap-1.5">
          <div class="p-2.5 bg-white/5 border border-white/10 rounded-xl">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-blue-400">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v5.75c0 .621-.504 1.125-1.125 1.125h-2.25A1.125 1.125 0 0 1 3 18.875v-5.75Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v10.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v14.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
            </svg>
          </div>
          <span class="text-xs font-medium tracking-wide">Analytics</span>
        </div>
      </div>
    </div>
  </div>
</div>