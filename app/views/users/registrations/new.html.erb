<%# app/views/users/registrations/new.html.erb %>
<div class="min-h-screen bg-slate-50 font-sans antialiased text-slate-900 flex flex-col lg:flex-row">
  <!-- Left Column: Registration Workspace -->
  <div class="w-full lg:w-[55%] flex flex-col justify-center p-6 sm:p-10 md:p-16 bg-white shadow-xl lg:shadow-none">
    <div class="w-full max-w-md mx-auto">
      <!-- App Header Branding -->
      <div class="flex items-center gap-2.5 mb-8">
        <div class="h-9 w-9 rounded-xl bg-indigo-600 flex items-center justify-center shadow-md shadow-indigo-100">
          <span class="text-white font-black text-sm tracking-wider">R</span>
        </div>
        <span class="text-lg font-black text-slate-900 tracking-tight">
          Retail<span class="text-indigo-600">OS</span>
        </span>
      </div>
      <!-- Heading -->
      <div class="mb-6">
        <h1 class="text-2xl font-extrabold tracking-tight text-slate-900 sm:text-3xl">Create your account</h1>
        <p class="text-slate-500 text-sm mt-1">Join RetailOS and modernize your store management in minutes.</p>
      </div>
      <!-- Core Form -->
     <%= form_for(resource, as: resource_name, url: signup_path, html: { class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <!-- User Information Fields -->
      <div class="space-y-4">
        <div>
          <%= f.label :full_name, "Full Name", class: "block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5" %>
          <%= f.text_field :full_name, autofocus: true, placeholder: "John Doe", 
                class: "block w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 text-sm transition" %>
        </div>
        <div>
          <%= f.label :email, class: "block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5" %>
          <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com", 
                class: "block w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 text-sm transition" %>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :password, class: "block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5" %>
            <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••", 
                  class: "block w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 text-sm transition" %>
          </div>
          <div>
            <%= f.label :password_confirmation, "Confirm Password", class: "block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••", 
                  class: "block w-full px-3.5 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 text-sm transition" %>
          </div>
        </div>
      </div>
      <!-- Shop Tenant Custom Configurations -->
      <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
        <div class="flex items-center gap-2 mb-3">
          <span class="h-1.5 w-1.5 rounded-full bg-indigo-600"></span>
          <h3 class="text-xs font-bold uppercase tracking-widest text-slate-600">Shop Details</h3>
        </div>
        <%= f.fields_for :memberships do |membership_fields| %>
          <%= membership_fields.fields_for :store do |store_fields| %>
            <div class="space-y-3">
              <div>
                <%= store_fields.label :name, "Shop Name", class: "block text-xs font-semibold text-slate-600 mb-1" %>
                <%= store_fields.text_field :name, required: true, placeholder: "e.g., Apex Emporium", 
                      class: "block w-full px-3.5 py-2 bg-white border border-slate-200 rounded-xl focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 text-sm transition" %>
              </div>
              <div>
                <%= store_fields.label :location, "Store Location / Branch", class: "block text-xs font-semibold text-slate-600 mb-1" %>
                <%= store_fields.text_field :location, required: true, placeholder: "e.g., East Legon, Accra", 
                      class: "block w-full px-3.5 py-2 bg-white border border-slate-200 rounded-xl focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 text-sm transition" %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
      <!-- Actions -->
      <div class="pt-1">
        <%= f.submit "Create Account & Store", 
              data: { disable_with: "Setting up your workspace..." },
              class: "w-full cursor-pointer bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-4 rounded-xl transition shadow-md shadow-indigo-100 hover:shadow-lg hover:shadow-indigo-200 text-sm" %>
      </div>
    <% end %>
    <!-- Authentication Resource Links -->
    <div class="mt-6 text-center text-xs text-slate-400 font-medium">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
<!-- Right Column: Context Marketing Display (Sticky Panel on Desktop) -->
<div class="hidden lg:flex lg:w-[45%] bg-[#0a255c] relative items-center justify-center p-12 lg:sticky lg:top-0 lg:h-screen overflow-hidden">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#0c2c6d_1px,transparent_1px),linear-gradient(to_bottom,#0c2c6d_1px,transparent_1px)] bg-[size:3rem_3rem] opacity-20"></div>
  <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] bg-indigo-500/10 rounded-full blur-[100px]"></div>
  <div class="absolute -top-20 -right-20 w-[400px] h-[400px] bg-sky-500/10 rounded-full blur-[100px]"></div>
  <div class="z-10 w-full max-w-sm">
    <div class="text-left mb-6">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold text-indigo-300 bg-indigo-500/10 border border-indigo-500/20 mb-3 uppercase tracking-widest">
        Introducing RetailOS
      </span>
      <h2 class="text-2xl lg:text-3xl font-extrabold text-white leading-snug tracking-tight">Your retail business, fully optimized.</h2>
      <p class="text-slate-300 text-sm mt-2 leading-relaxed">Fast checkouts, smart inventory controls, and robust analytical tools built for modern merchants.</p>
    </div>
    <!-- Mini Live Dashboard Specimen Mockup -->
    <div class="bg-[#0c2e71]/40 border border-indigo-400/10 rounded-xl p-5 backdrop-blur-md shadow-xl">
      <div class="flex items-center justify-between pb-3 border-b border-indigo-500/20 mb-3">
        <div class="flex items-center gap-1.5">
          <span class="h-2 w-2 rounded-full bg-red-500/70"></span>
          <span class="h-2 w-2 rounded-full bg-yellow-500/70"></span>
          <span class="h-2 w-2 rounded-full bg-green-500/70"></span>
        </div>
        <div class="text-[9px] font-bold text-indigo-300 tracking-wider uppercase">Live Insights</div>
      </div>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <div class="bg-[#082252]/60 p-3 rounded-lg border border-indigo-500/5">
          <p class="text-[9px] uppercase font-semibold text-slate-400 tracking-wider">Gross Revenue</p>
          <p class="text-base font-bold text-white mt-0.5">₵42,890.50</p>
        </div>
        <div class="bg-[#082252]/60 p-3 rounded-lg border border-indigo-500/5">
          <p class="text-[9px] uppercase font-semibold text-slate-400 tracking-wider">Sales Completed</p>
          <p class="text-base font-bold text-indigo-400 mt-0.5">154 <span class="text-[10px] text-emerald-400 font-bold ml-0.5">↑12%</span></p>
        </div>
      </div>
      <div class="space-y-1.5">
        <div class="flex justify-between text-[11px] font-medium text-slate-300">
          <span>Inventory Capacity</span>
          <span>84%</span>
        </div>
        <div class="w-full bg-[#082252] rounded-full h-1.5">
          <div class="bg-indigo-500 h-1.5 rounded-full" style="width: 84%"></div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>