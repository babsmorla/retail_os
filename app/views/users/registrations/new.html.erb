<%# app/views/users/registrations/new.html.erb %>
<div class="min-h-screen flex flex-col lg:flex-row bg-slate-50 font-sans antialiased text-slate-900">
  <!-- Left Column: Form Container -->
  <div class="w-full lg:w-[55%] flex flex-col justify-between p-8 sm:p-12 md:p-16 lg:p-20 xl:p-24 max-w-2xl mx-auto lg:max-w-none bg-white shadow-xl shadow-slate-100 z-10">
    <!-- Logo Header -->
    <div class="flex items-center gap-3 mb-10 lg:mb-0">
      <div class="h-10 w-10 rounded-xl bg-indigo-600 flex items-center justify-center shadow-lg shadow-indigo-200">
        <span class="text-white font-extrabold text-base tracking-wider">R</span>
      </div>
      <span class="text-xl font-extrabold text-slate-900 tracking-tight">
        Retail<span class="text-indigo-600">OS</span>
      </span>
    </div>
    <!-- Main Signup Form Content -->
    <div class="w-full max-w-md mx-auto lg:mx-0 my-auto py-8">
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 mb-2">Create your account</h1>
      <p class="text-slate-500 text-sm mb-8">Join RetailOS and modernize your store management in minutes.</p>
      <%# CORRECTION: changed 'signup_path(resource_name)' to 'signup_path' to prevent the '.user' unknown format error %>
      <%= form_for(resource, as: resource_name, url: signup_path, html: { class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <div class="space-y-4">
          <!-- Full Name -->
          <div>
            <%= f.label :full_name, "Full Name", class: "block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5" %>
            <%= f.text_field :full_name, autofocus: true, placeholder: "John Doe", 
                class: "block w-full px-4 py-3 bg-slate-50/50 border border-slate-200 rounded-xl focus:bg-white focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 text-sm transition duration-150" %>
          </div>
          <!-- Email -->
          <div>
            <%= f.label :email, class: "block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5" %>
            <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com", 
                class: "block w-full px-4 py-3 bg-slate-50/50 border border-slate-200 rounded-xl focus:bg-white focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 text-sm transition duration-150" %>
          </div>
          <!-- Passwords Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :password, class: "block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5" %>
              <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••", 
                  class: "block w-full px-4 py-3 bg-slate-50/50 border border-slate-200 rounded-xl focus:bg-white focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 text-sm transition duration-150" %>
            </div>
            <div>
              <%= f.label :password_confirmation, "Confirm Password", class: "block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••", 
                  class: "block w-full px-4 py-3 bg-slate-50/50 border border-slate-200 rounded-xl focus:bg-white focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 text-sm transition duration-150" %>
            </div>
          </div>
        </div>
        <!-- Nested Store Creation Box -->
        <div class="bg-slate-50/60 rounded-2xl p-5 border border-slate-100 mt-6">
          <div class="flex items-center gap-2 mb-4">
            <span class="h-2 w-2 rounded-full bg-indigo-600 animate-pulse"></span>
            <h3 class="text-xs font-bold uppercase tracking-widest text-slate-700">Shop Details</h3>
          </div>
          <%= f.fields_for :memberships do |membership_fields| %>
            <%= membership_fields.fields_for :store do |store_fields| %>
              <div class="space-y-4">
                <div>
                  <%= store_fields.label :name, "Shop Name", class: "block text-xs font-semibold text-slate-600 mb-1.5" %>
                  <%= store_fields.text_field :name, required: true, placeholder: "e.g., Apex Emporium", 
                      class: "block w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 text-sm transition duration-150" %>
                </div>
                <div>
                  <%= store_fields.label :location, "Store Location / Branch", class: "block text-xs font-semibold text-slate-600 mb-1.5" %>
                  <%= store_fields.text_field :location, required: true, placeholder: "e.g., East Legon, Accra", 
                      class: "block w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 text-sm transition duration-150" %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
        <!-- Submit Action (Double-click protection included!) -->
        <div class="pt-2">
          <%= f.submit "Create Account & Store", 
              data: { disable_with: "Setting up your workspace..." },
              class: "w-full cursor-pointer bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3.5 px-4 rounded-xl transition duration-150 shadow-md shadow-indigo-200 hover:shadow-lg hover:shadow-indigo-300" %>
        </div>
      <% end %>
      <div class="mt-8 text-center text-xs text-slate-400 font-medium">
        <%= render "devise/shared/links" %>
      </div>
    </div>
    <div class="hidden lg:block"></div>
  </div>
  <!-- Right Column: Live Marketing Visuals (Desktop Only) -->
  <div class="hidden lg:flex lg:w-[45%] bg-[#0a255c] relative items-center justify-center p-16 overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#0c2c6d_1px,transparent_1px),linear-gradient(to_bottom,#0c2c6d_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-30"></div>
    <div class="absolute -bottom-20 -left-20 w-[450px] h-[450px] bg-indigo-500/20 rounded-full blur-[120px]"></div>
    <div class="absolute -top-20 -right-20 w-[450px] h-[450px] bg-sky-500/10 rounded-full blur-[120px]"></div>
    <div class="z-10 w-full max-w-lg">
      <div class="text-left mb-8">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold text-indigo-300 bg-indigo-500/10 border border-indigo-500/20 mb-4 uppercase tracking-widest">
          Introducing RetailOS
        </span>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-white leading-tight tracking-tight">Your retail business, fully optimized.</h2>
        <p class="text-slate-300 text-base mt-2 leading-relaxed">Fast checkouts, smart inventory controls, and robust analytical tools built for modern merchants.</p>
      </div>
      <!-- Interactive Dashboard Mockup -->
      <div class="bg-[#0c2e71]/60 border border-indigo-400/20 rounded-2xl p-6 backdrop-blur-lg shadow-2xl relative">
        <div class="flex items-center justify-between pb-4 border-b border-indigo-500/20 mb-4">
          <div class="flex items-center gap-2">
            <span class="h-3 w-3 rounded-full bg-red-500/80"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-500/80"></span>
            <span class="h-3 w-3 rounded-full bg-green-500/80"></span>
          </div>
          <div class="px-2.5 py-0.5 rounded-full bg-indigo-500/20 text-[10px] font-bold text-indigo-300 tracking-wider uppercase">Live Insights</div>
        </div>
        <div class="grid grid-cols-2 gap-4 mb-4">
          <div class="bg-[#082252]/80 border border-indigo-500/10 p-3.5 rounded-xl">
            <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Gross Revenue</p>
            <p class="text-lg font-extrabold text-white mt-1">₵42,890.50</p>
          </div>
          <div class="bg-[#082252]/80 border border-indigo-500/10 p-3.5 rounded-xl">
            <p class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Sales Completed</p>
            <p class="text-lg font-extrabold text-indigo-400 mt-1">154 <span class="text-xs text-emerald-400 font-bold ml-1">↑ 12%</span></p>
          </div>
        </div>
        <div class="space-y-2">
          <div class="flex justify-between text-xs font-semibold text-slate-300">
            <span>Inventory Capacity</span>
            <span>84%</span>
          </div>
          <div class="w-full bg-[#082252] rounded-full h-2">
            <div class="bg-indigo-500 h-2 rounded-full" style="width: 84%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>